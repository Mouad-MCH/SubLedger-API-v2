{
  "name": "subledger-api",
  "version": "1.0.0",
  "description": "SubLedger API is a secure Node.js backend for managing digital subscriptions. It features JWT authentication, role-based access (User/Admin), bcrypt password hashing, and CRUD operations for subscriptions, with input validation and protected routes using Express and MongoDB.",
