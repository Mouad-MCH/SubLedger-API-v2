    "url": "git+https://github.com/elhajjame/subledger-api.git"
  },
  "license": "ISC",
  "author": "mehdi",
  "type": "module",
  "main": "app.js",
  "scripts": {
    "start": "nodemon server.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongoos": "^0.0.1-security",
    "mongoose": "^9.2.4",
    "morgan": "^1.10.1",
    "nodemon": "^3.1.14",
    "validator": "^13.15.26"
  }
